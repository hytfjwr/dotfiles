[
  {
    "key": "alt+cmd+' alt+cmd+;",
    "command": "keybindings.editor.recordSearchKeys",
    "when": "inKeybindings && inKeybindingsSearch"
  },
  {
    "key": "alt+cmd+k",
    "command": "-keybindings.editor.recordSearchKeys",
    "when": "inKeybindings && inKeybindingsSearch"
  },
  {
    "key": "alt+cmd+,",
    "command": "git.pushTo",
    "when": "!inDebugMode && !operationInProgress && !terminalFocus"
  },
  {
    "key": "alt+cmd+k",
    "command": "-git.pushTo",
    "when": "!inDebugMode && !operationInProgress && !terminalFocus"
  },
  {
    "key": "shift+enter",
    "command": "-repl.execute",
    "when": "config.interactiveWindow.executeWithShiftEnter && isCompositeNotebook && !notebookCellListFocused && activeEditor == 'workbench.editor.repl'"
  },
  {
    "key": "shift+enter",
    "command": "-workbench.action.terminal.sendSequence",
    "when": "terminalFocus && terminalShellIntegrationEnabled && !accessibilityModeEnabled && terminalShellType == 'pwsh'"
  }
]
