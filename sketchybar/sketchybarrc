# This is a demo config to showcase some of the most important commands.
# It is meant to be changed and configured, as it is intentionally kept sparse.
# For a (much) more advanced configuration example see my dotfiles:
# https://github.com/FelixKratz/dotfiles

PLUGIN_DIR="$CONFIG_DIR/plugins"
source "$CONFIG_DIR/colors.sh"

##### Bar Appearance #####
# Configuring the general appearance of the bar.
# These are only some of the options available. For all options see:
# https://felixkratz.github.io/SketchyBar/config/bar
# If you are looking for other colors, see the color picker:
# https://felixkratz.github.io/SketchyBar/config/tricks#color-picker

sketchybar --bar position=top height=44 blur_radius=30 color=0x40000000

##### Changing Defaults #####
# We now change some default values, which are applied to all further items.
# For a full list of all available item properties see:
# https://felixkratz.github.io/SketchyBar/config/items

default=(
  padding_left=5
  padding_right=5
  icon.font="Hack Nerd Font:Bold:17.0"
  label.font="SF Pro:Bold:14.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

##### Adding AeroSpace Workspace Indicators #####
# AeroSpace workspace integration
# https://nikitabobko.github.io/AeroSpace/goodies

# カスタムイベントを追加
sketchybar --add event aerospace_workspace_change \
           --add event space_windows_change

# AeroSpaceワークスペース表示
source "$CONFIG_DIR/items/spaces.sh"

##### Adding Left Items #####
# We add some regular items to the left side of the bar, where
# only the properties deviating from the current defaults need to be set

sketchybar --add item chevron left \
           --set chevron icon= label.drawing=off \
           --add item front_app left \
           --set front_app icon.drawing=off script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

##### Adding Right Items #####
# In the same way as the left items we can add items to the right side.
# Additional position (e.g. center) are available, see:
# https://felixkratz.github.io/SketchyBar/config/items#adding-items-to-sketchybar

# Some items refresh on a fixed cycle, e.g. the clock runs its script once
# every 10s. Other items respond to events they subscribe to, e.g. the
# volume.sh script is only executed once an actual change in system audio
# volume is registered. More info about the event system can be found here:
# https://felixkratz.github.io/SketchyBar/config/events

sketchybar --add item time right \
           --set time update_freq=2 \
                 icon.padding_right=0 \
                 label.padding_left=0 \
                 script="$PLUGIN_DIR/time.sh" \
           --add item date right \
           --set date update_freq=60 \
                 background.color=0xffe8e8e9 \
                 label.color=0xff000000 \
                 label.font="SF Pro:Semibold:12" \
                 icon.padding_right=0 \
                 label.padding_left=0 \
                 background.height=15 \
                 background.corner_radius=4 \
                 script="$PLUGIN_DIR/date.sh" \
           --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change \
           --add item battery right \
           --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

##### Focus Timer #####
source "$CONFIG_DIR/items/focus_timer.sh"

# システムモニター（左から右の順：Docker、VPN、ネットワーク、メモリアイコン+グラフ、CPUアイコン+グラフ）
##### Docker Container Status #####
source "$CONFIG_DIR/items/docker.sh"

source "$CONFIG_DIR/items/vpn.sh"

sketchybar --add item network_up right \
           --set network_up label.font="SF Pro:Heavy:9" \
                 icon.font="SF Pro:Heavy:9" \
                 icon=▲ \
                 icon.highlight_color=0xff8b0a0d \
                 y_offset=5 \
                 width=0 \
                 update_freq=2 \
                 script="$PLUGIN_DIR/network.sh" \
           --add item network_down right \
           --set network_down label.font="SF Pro:Heavy:9" \
                 icon.font="SF Pro:Heavy:9" \
                 icon=▼ \
                 icon.highlight_color=0xff10528c \
                 y_offset=-5 \
           --add graph memory_graph right 50 \
           --set memory_graph width=28 \
                 graph.height=12 \
                 graph.color=0xff00ff00 \
                 graph.fill_color=0x2000ff00 \
                 background.height=16 \
                 background.corner_radius=8 \
                 background.padding_left=3 \
                 background.padding_right=3 \
                 background.border_width=0 \
                 padding_left=0 \
                 padding_right=0 \
                 y_offset=9 \
                 icon.drawing=off \
                 label.drawing=off \
                 update_freq=2 \
                 script="$PLUGIN_DIR/memory.sh" \
                 click_script="open -a 'Activity Monitor'" \
           --add item graph_spacer right \
           --set graph_spacer width=20 \
                 icon.drawing=off \
                 label.drawing=off \
                 background.drawing=off \
                 padding_left=0 \
                 padding_right=0 \
           --add graph cpu_graph right 50 \
           --set cpu_graph width=28 \
                 graph.height=12 \
                 graph.color=0xff0099ff \
                 graph.fill_color=0x200099ff \
                 background.height=16 \
                 background.corner_radius=8 \
                 background.padding_left=3 \
                 background.padding_right=3 \
                 background.border_width=0 \
                 padding_left=0 \
                 padding_right=0 \
                 y_offset=9 \
                 icon.drawing=off \
                 label.drawing=off \
                 update_freq=2 \
                 script="$PLUGIN_DIR/cpu.sh" \
                 click_script="open -a 'Activity Monitor'"

##### Spotify Integration #####
source "$CONFIG_DIR/items/spotify.sh"

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
